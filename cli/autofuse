    printf "\n"
}

# ─── Command dispatch ────────────────────────────────────────────────────────

case "${1:-}" in
    ""|status)
        cmd_status
        ;;
    connect)
        cmd_connect "${2:-}"
        ;;
    json)
        shift
        cmd_json "$@"
        ;;
    raw)
        # Direct engine access: every mount.sh subcommand, including ones
        # without a friendly wrapper (host keys, endpoint cache, panic, ...).
        shift
        exec bash "$MOUNT_SH" "$@"
        ;;
    mount)
        cmd_mount "${2:-}" "${3:-}"
        ;;
    unmount)
        cmd_unmount "${2:-}" "${3:-}"
        ;;
    wake)
        cmd_wake "${2:-}"
        ;;
    heal)
        cmd_heal
        ;;
    discover)
        cmd_discover
        ;;
    probe)
        cmd_probe "${2:-}"
        ;;
    add)
        cmd_add
        ;;
    config)
        cmd_config
        ;;
    log)
        cmd_log
        ;;
    version|--version|-v)
        cmd_version
        ;;
    help|--help|-h)
        cmd_help
        ;;
    *)
        printf "${RED}Unknown command:${NC} %s\n\n" "$1"
        cmd_help
        exit 1
        ;;
esac
